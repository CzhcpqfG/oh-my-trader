# ============ LLM API 配置 ============
# 支持的 provider: deepseek (默认) / openai / tongyi (通义) / zhipu (智谱) / claude / custom
# deepseek/openai/tongyi/zhipu/custom 走 OpenAI 兼容 /chat/completions 协议
# claude 走 Anthropic SDK, 需要 LLM_CLAUDE_API_KEY
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI 兼容基础 URL (provider=claude 时可忽略)
LLM_BASE_URL=https://api.deepseek.com
# 模型名 (provider=claude 时可忽略)
LLM_MODEL=deepseek-chat
# Claude 专用 (provider=claude 时必填)
LLM_CLAUDE_API_KEY=
LLM_CLAUDE_MODEL=claude-sonnet-4-20250514
# LLM 温度 (0-1, 越高越有创造性, 建议 0.6-0.9)
LLM_TEMPERATURE=0.8

# ============ 报告内容配置 ============
# 启用哪些市场 (逗号分隔), 可选: a_share,us_stock,macro,crypto,futures,forex
ENABLED_MARKETS=a_share,us_stock,macro,crypto

# ============ 邮件配置 (QQ邮箱) ============
# 1. 登录QQ邮箱 → 设置 → 账户 → 开启SMTP服务 → 生成授权码
# 2. 授权码填到下面, 不是QQ密码
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your-qq@qq.com
EMAIL_PASS=your-授权码-非QQ密码
EMAIL_TO=your-qq@qq.com
# 多个收件人用逗号分隔: EMAIL_TO=a@x.com,b@x.com
EMAIL_SUBJECT_PREFIX=[今日风水报告]
